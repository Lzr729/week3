{"schema_version": "1.0", "company_code": "301563", "company_name": "云汉芯城", "package_id": "301563_share_transfer_flow_003", "event_id": "301563_share_transfer_flow_003_evt_001", "event_family": "share_transfer_flow", "event_title": "2019年8月第三次股权转让", "transfer_subtype": "employee_platform_internal", "decision_date": null, "agreement_date": {"raw_text": "2019年8月13日", "iso_date": "2019-08-13"}, "payment_date": null, "registration_date": null, "effective_date": null, "target_company_name": "云汉芯城", "target_security_type": "equity_interest", "target_is_issuer": true, "target_confirmation": {"raw_text": "（三）2019年8月，股份公司第三次股权转让2019年8月13日，为赛咨询与李文发、秦国君分别签署了《股份转让协议》。根据该协议，李文发以40万元的价格受让为赛咨询持有的发行人股份40万股，秦国君以40万元的价格受让为赛咨询持有的发行人股份40万股。同时，李文发、秦国君与为赛咨询其他合伙人签署了《退伙协议书》，两人于2019年8月12日将其依据2017年公司员工激励方案以40万元的价格各取得的为赛咨询21.58%的财产份额转出，进而从为赛咨询退伙。本次转让后，公司的股权结构如下：序号股东姓名/名称持股数量（股）持股比例（%）1曾烨17,096,75036.892刘云锋6,949,86014.9", "confirmed_by": "chapter_context"}, "source_pages": [61, 62], "evidence": [{"page": 61, "evidence_role": "agreement", "text": "2019年8月13日"}], "transfers": [], "total_transferred_registered_capital": null, "total_transferred_shares": null, "total_transferred_ratio": null, "total_consideration": null, "pre_event_snapshot_present": false, "pre_event_snapshot_pages": [], "post_event_snapshot_present": true, "post_event_snapshot_pages": [61], "currency": "CNY", "notes": "V1规则抽取结果；后续需进行Schema校验、字段级Gold比较和人工复核。", "needs_manual_review": true, "review_reasons": ["decision_date_not_found", "transfer_items_not_found", "transferor_or_transferee_not_found"]}
{"schema_version": "1.0", "company_code": "301563", "company_name": "云汉芯城", "package_id": "301563_share_transfer_flow_004", "event_id": "301563_share_transfer_flow_004_evt_001", "event_family": "share_transfer_flow", "event_title": "2020年9月第四次股权转让", "transfer_subtype": "ordinary_transfer", "decision_date": {"raw_text": "2020年9月15日", "iso_date": "2020-09-15"}, "agreement_date": null, "payment_date": null, "registration_date": null, "effective_date": null, "target_company_name": "云汉芯城", "target_security_type": "equity_interest", "target_is_issuer": true, "target_confirmation": {"raw_text": "（五）2020年9月，股份公司第三次增资和第四次股权转让2020年9月15日，发行人召开2020年第三次临时股东大会并通过决议，同意发行人的注册资本由4,748.0488万元增至4,883.7074万元。其中，厦门西堤以5,000.00万元认购公司新增股份96.899万股，96.899万元计入股本，剩余部分计入资本公积；中小企业基金以2,000.00万元认购新增股份38.7596万股，38.7596万元计入股本，剩余部分计入资本公积。2020年12月16日，容诚会计师出具了《验资报告》（容诚验字云汉芯城（上海）互联网科技股份有限公司招股说明书63[2020]361Z0117号），对本次增资进行", "confirmed_by": "chapter_context"}, "source_pages": [63, 64, 65], "evidence": [{"page": 63, "evidence_role": "decision", "text": "2020年9月15日"}], "transfers": [], "total_transferred_registered_capital": null, "total_transferred_shares": null, "total_transferred_ratio": null, "total_consideration": null, "pre_event_snapshot_present": false, "pre_event_snapshot_pages": [], "post_event_snapshot_present": false, "post_event_snapshot_pages": [], "currency": "CNY", "notes": "V1规则抽取结果；后续需进行Schema校验、字段级Gold比较和人工复核。", "needs_manual_review": true, "review_reasons": ["agreement_date_not_found", "transfer_items_not_found", "transferor_or_transferee_not_found"]}
