{"schema_version": "1.0", "company_code": "301563", "company_name": "云汉芯城", "package_id": "301563_share_transfer_flow_001", "event_id": "301563_share_transfer_flow_001_evt_001", "event_family": "share_transfer_flow", "event_title": "2018年4月第一次股权转让", "transfer_subtype": "ordinary_transfer", "decision_date": null, "agreement_date": {"raw_text": "2018年4月28日", "iso_date": "2018-04-28"}, "payment_date": null, "registration_date": null, "effective_date": null, "target_company_name": "云汉芯城", "target_security_type": "equity_interest", "target_is_issuer": true, "target_confirmation": {"raw_text": "（一）2018年4月，股份公司第一次股权转让2018年4月28日，丰利财富与天健创投签署了《关于云汉芯城（上海）互联网科技股份有限公司股份转让协议》，约定丰利财富将其持有的云汉芯城全部666,680股股份（占总股本的1.67%）转让给天健创投，转让价格系按照丰利财富2015年入股云汉有限时的投资总额1,000万元确定。丰利财富系代表其管理的丰利财富新三板成长基金（以下简称“丰利新三板基金”）投资发行人，资金来源为丰利新三板基金的募集资金。由于2018年丰利新三板基金拟转让发行人股份时，其存续期限已临近届满，基金所投资的项目退出压力较大，急于寻找退出的渠道，因此丰利财富同意按其出资时的价格100", "confirmed_by": "chapter_context"}, "source_pages": [58, 59], "evidence": [{"page": 58, "evidence_role": "agreement", "text": "2018年4月28日"}], "transfers": [], "total_transferred_registered_capital": null, "total_transferred_shares": null, "total_transferred_ratio": null, "total_consideration": null, "pre_event_snapshot_present": false, "pre_event_snapshot_pages": [], "post_event_snapshot_present": true, "post_event_snapshot_pages": [58], "currency": "CNY", "notes": "V1规则抽取结果；后续需进行Schema校验、字段级Gold比较和人工复核。", "needs_manual_review": true, "review_reasons": ["decision_date_not_found", "transfer_items_not_found", "transferor_or_transferee_not_found"]}
