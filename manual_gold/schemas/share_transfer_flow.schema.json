{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "share_transfer_flow.schema.json",
  "title": "IPO Share Transfer Flow",
  "description": "发行人股份或股权转让事件的结构化字段规范，重点确认被转让标的是发行人本身，而不是上层公司、员工持股平台或其他企业。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "company_code",
    "company_name",
    "package_id",
    "event_id",
    "event_family",
    "event_title",
    "transfer_subtype",
    "target_company_name",
    "target_is_issuer",
    "target_confirmation",
    "source_pages",
    "evidence",
    "transfers",
    "total_transferred_registered_capital",
    "total_transferred_shares",
    "total_transferred_ratio",
    "total_consideration",
    "pre_event_snapshot_present",
    "pre_event_snapshot_pages",
    "post_event_snapshot_present",
    "post_event_snapshot_pages",
    "needs_manual_review",
    "review_reasons"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "company_code": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_family": {
      "type": "string",
      "const": "share_transfer_flow"
    },
    "event_title": {
      "type": "string",
      "minLength": 1
    },
    "transfer_subtype": {
      "type": "string",
      "enum": [
        "ordinary_transfer",
        "nominee_release",
        "gift_or_inheritance",
        "internal_restructuring",
        "employee_platform_internal",
        "judicial_transfer",
        "other"
      ]
    },
    "decision_date": {
      "$ref": "#/$defs/date_value"
    },
    "agreement_date": {
      "$ref": "#/$defs/date_value"
    },
    "payment_date": {
      "$ref": "#/$defs/date_value"
    },
    "registration_date": {
      "$ref": "#/$defs/date_value"
    },
    "effective_date": {
      "$ref": "#/$defs/date_value"
    },
    "target_company_name": {
      "type": "string",
      "minLength": 1
    },
    "target_security_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "equity_interest",
        "shares",
        "registered_capital",
        "partnership_interest",
        "other",
        null
      ]
    },
    "target_is_issuer": {
      "type": "boolean"
    },
    "target_confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_text",
        "confirmed_by"
      ],
      "properties": {
        "raw_text": {
          "type": "string",
          "minLength": 1
        },
        "confirmed_by": {
          "type": "string",
          "enum": [
            "explicit_issuer_name",
            "issuer_alias",
            "chapter_context",
            "post_transfer_snapshot",
            "multiple_evidence",
            "manual_confirmation"
          ]
        }
      }
    },
    "source_pages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "transfers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/transfer_item"
      }
    },
    "total_transferred_registered_capital": {
      "$ref": "#/$defs/numeric_value"
    },
    "total_transferred_shares": {
      "$ref": "#/$defs/numeric_value"
    },
    "total_transferred_ratio": {
      "$ref": "#/$defs/numeric_value"
    },
    "total_consideration": {
      "$ref": "#/$defs/numeric_value"
    },
    "pre_event_snapshot_present": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "pre_event_snapshot_pages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "post_event_snapshot_present": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "post_event_snapshot_pages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "currency": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "CNY",
        "USD",
        "HKD",
        "EUR",
        null
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "needs_manual_review": {
      "type": "boolean"
    },
    "review_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "date_value": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "raw_text",
        "iso_date"
      ],
      "properties": {
        "raw_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "iso_date": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "numeric_value": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "raw_text",
        "value",
        "unit",
        "normalized_value",
        "normalized_unit"
      ],
      "properties": {
        "raw_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "number",
            "null"
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "元",
            "万元",
            "亿元",
            "股",
            "万股",
            "%",
            "元/股",
            "元/注册资本",
            "万元/注册资本",
            "其他",
            null
          ]
        },
        "normalized_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "normalized_unit": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "CNY",
            "share",
            "percent",
            "CNY_per_share",
            "CNY_per_registered_capital",
            "other",
            null
          ]
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "evidence_role",
        "text"
      ],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "evidence_role": {
          "type": "string",
          "enum": [
            "decision",
            "agreement",
            "target_confirmation",
            "transferor",
            "transferee",
            "quantity",
            "ratio",
            "price",
            "payment",
            "registration",
            "pre_event_snapshot",
            "post_event_snapshot",
            "other"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transfer_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transferor_name",
        "transferee_name",
        "transferred_registered_capital",
        "transferred_shares",
        "transferred_ratio",
        "consideration",
        "price_per_share",
        "price_per_registered_capital",
        "payment_method",
        "notes"
      ],
      "properties": {
        "transferor_name": {
          "type": "string",
          "minLength": 1
        },
        "transferee_name": {
          "type": "string",
          "minLength": 1
        },
        "transferred_registered_capital": {
          "$ref": "#/$defs/numeric_value"
        },
        "transferred_shares": {
          "$ref": "#/$defs/numeric_value"
        },
        "transferred_ratio": {
          "$ref": "#/$defs/numeric_value"
        },
        "consideration": {
          "$ref": "#/$defs/numeric_value"
        },
        "price_per_share": {
          "$ref": "#/$defs/numeric_value"
        },
        "price_per_registered_capital": {
          "$ref": "#/$defs/numeric_value"
        },
        "payment_method": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "cash",
            "equity_swap",
            "gift",
            "inheritance",
            "zero_consideration",
            "other",
            null
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}