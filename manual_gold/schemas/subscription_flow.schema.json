{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "subscription_flow.schema.json",
  "title": "IPO Subscription Flow",
  "description": "发行人设立、增资、定向发行、吸收合并增资等资本流入事件的结构化字段规范。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "company_code",
    "company_name",
    "package_id",
    "event_id",
    "event_family",
    "event_title",
    "flow_subtype",
    "source_pages",
    "evidence",
    "registration_capital_before",
    "registration_capital_after",
    "total_shares_before",
    "total_shares_after",
    "new_registered_capital",
    "new_shares",
    "total_consideration",
    "participants",
    "needs_manual_review",
    "review_reasons"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "company_code": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_family": {
      "type": "string",
      "const": "subscription_flow"
    },
    "event_title": {
      "type": "string",
      "minLength": 1
    },
    "flow_subtype": {
      "type": "string",
      "enum": [
        "establishment_subscription",
        "cash_increase",
        "in_kind_increase",
        "debt_to_equity",
        "merger_increase",
        "private_placement",
        "capitalization",
        "mixed_increase",
        "other"
      ]
    },
    "decision_date": {
      "$ref": "#/$defs/date_value"
    },
    "agreement_date": {
      "$ref": "#/$defs/date_value"
    },
    "payment_date": {
      "$ref": "#/$defs/date_value"
    },
    "verification_date": {
      "$ref": "#/$defs/date_value"
    },
    "registration_date": {
      "$ref": "#/$defs/date_value"
    },
    "effective_date": {
      "$ref": "#/$defs/date_value"
    },
    "source_pages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "registration_capital_before": {
      "$ref": "#/$defs/numeric_value"
    },
    "registration_capital_after": {
      "$ref": "#/$defs/numeric_value"
    },
    "total_shares_before": {
      "$ref": "#/$defs/numeric_value"
    },
    "total_shares_after": {
      "$ref": "#/$defs/numeric_value"
    },
    "new_registered_capital": {
      "$ref": "#/$defs/numeric_value"
    },
    "new_shares": {
      "$ref": "#/$defs/numeric_value"
    },
    "total_consideration": {
      "$ref": "#/$defs/numeric_value"
    },
    "capital_premium": {
      "$ref": "#/$defs/numeric_value"
    },
    "participants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/participant"
      }
    },
    "post_event_snapshot_present": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "post_event_snapshot_pages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "currency": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "CNY",
        "USD",
        "HKD",
        "EUR",
        null
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "needs_manual_review": {
      "type": "boolean"
    },
    "review_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "date_value": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "raw_text",
        "iso_date"
      ],
      "properties": {
        "raw_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "iso_date": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "numeric_value": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "raw_text",
        "value",
        "unit",
        "normalized_value",
        "normalized_unit"
      ],
      "properties": {
        "raw_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "number",
            "null"
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "元",
            "万元",
            "亿元",
            "股",
            "万股",
            "%",
            "元/股",
            "元/注册资本",
            "万元/注册资本",
            "其他",
            null
          ]
        },
        "normalized_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "normalized_unit": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "CNY",
            "share",
            "percent",
            "CNY_per_share",
            "CNY_per_registered_capital",
            "other",
            null
          ]
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "evidence_role",
        "text"
      ],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "evidence_role": {
          "type": "string",
          "enum": [
            "decision",
            "agreement",
            "capital_change",
            "participant",
            "price",
            "payment",
            "verification",
            "registration",
            "post_event_snapshot",
            "other"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_name",
        "participant_role",
        "subscribed_registered_capital",
        "subscribed_shares",
        "contribution_amount",
        "price_per_share",
        "price_per_registered_capital",
        "contribution_method"
      ],
      "properties": {
        "participant_name": {
          "type": "string",
          "minLength": 1
        },
        "participant_role": {
          "type": "string",
          "enum": [
            "founding_shareholder",
            "existing_shareholder",
            "new_shareholder",
            "employee_platform",
            "institutional_investor",
            "merged_entity",
            "other"
          ]
        },
        "subscribed_registered_capital": {
          "$ref": "#/$defs/numeric_value"
        },
        "subscribed_shares": {
          "$ref": "#/$defs/numeric_value"
        },
        "contribution_amount": {
          "$ref": "#/$defs/numeric_value"
        },
        "price_per_share": {
          "$ref": "#/$defs/numeric_value"
        },
        "price_per_registered_capital": {
          "$ref": "#/$defs/numeric_value"
        },
        "contribution_method": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "cash",
            "physical_asset",
            "intellectual_property",
            "land_use_right",
            "net_assets",
            "capital_reserve",
            "debt",
            "merged_entity_net_assets",
            "mixed",
            "other",
            null
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}